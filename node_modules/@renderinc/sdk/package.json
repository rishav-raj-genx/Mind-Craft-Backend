{
  "name": "@renderinc/sdk",
  "version": "0.6.0",
  "description": "Render SDK for TypeScript",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "format": "biome format --write",
    "format:check": "biome format",
    "check": "biome check --write",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "render",
    "workflow",
    "sdk",
    "typescript"
  ],
  "author": "Render",
  "license": "MIT",
  "homepage": "https://render.com/docs/workflows-sdk-typescript",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/render-oss/sdk.git",
    "directory": "typescript"
  },
  "bugs": {
    "url": "https://github.com/render-oss/sdk/issues"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "^20.0.0",
    "openapi-typescript": "^7.10.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "eventsource": "^4.0.0",
    "openapi-fetch": "^0.15.0",
    "redis": "^5.11.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./workflows": {
      "types": "./dist/workflows/index.d.ts",
      "import": "./dist/workflows/index.js",
      "require": "./dist/workflows/index.js"
    },
    "./experimental": {
      "types": "./dist/experimental/index.d.ts",
      "import": "./dist/experimental/index.js",
      "require": "./dist/experimental/index.js"
    }
  }
}
